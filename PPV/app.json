{
  "expo": {
    "name": "PPV",
    "slug": "PPV",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/PPVlogo1.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/PPVlogo1.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/PPVlogo1.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.RECORD_AUDIO",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.RECORD_AUDIO"
      ],
      "package": "com.anonymous.PPV"
    },
    "web": {
      "favicon": "./assets/PPVlogo1.png"
    },
    "plugins": [
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Sovellus tarvitsee sijaintisi karttaa varten."
        }
      ],
      [
        "expo-image-picker",
        {
          "cameraPermission": "Sovellus tarvitsee kameraa kuvien ottamiseen karttaan."
        }
      ]
    ]
  }
}
